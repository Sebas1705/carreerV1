---
import type { Language } from '@/domain';
import { supportedLanguages, languageNames } from '@/domain';
import { siteUrl } from '@/core';

interface Props {
    currentLang: Language;
}

const { currentLang } = Astro.props;

// Build static href for each language by replacing the lang segment in the current path.
// Astro.url.pathname e.g. '/carreerV1/en/projects/some-id'
const currentPath = Astro.url.pathname;
const langSegmentPattern = /\/(es|en|fr|de|it|pt|nl|pl|ru|ja)(\/|$)/;

function langHref(lang: string): string {
    if (langSegmentPattern.test(currentPath)) {
        // Replace existing lang segment: /carreerV1/en/foo → /carreerV1/fr/foo
        return currentPath.replace(langSegmentPattern, `/${lang}$2`);
    }
    // Fallback: go to that language's home
    return siteUrl(`/${lang}/`);
}

const orderedLanguages = [
    currentLang,
    ...supportedLanguages.filter(l => l !== currentLang),
];
---

<div class="language-selector relative inline-block">
    <button
        class="language-button w-18 xs:w-22 responsive-header-h"
        aria-label="Change language"
        aria-expanded="false"
        aria-haspopup="listbox"
    >
        <span class="current-lang text-sm xs:text-xl">{currentLang.toUpperCase()}</span>
        <svg class="h-4 xs:h-6 sm:h-8 md:h-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6 9 12 15 18 9"/>
        </svg>
    </button>

    <ul
        role="listbox"
        aria-label="Languages"
        class="language-dropdown absolute top-full right-0 mt-2 bg-bg-surface-alt-v border-2 border-primary-v rounded-md shadow-lg list-none"
        hidden
    >
        {orderedLanguages.map((lng) => (
            <li role="option" aria-selected={lng === currentLang}>
                <a
                    href={langHref(lng)}
                    class={`language-option flex items-center gap-2 px-4 py-2 w-full text-left no-underline ${lng === currentLang ? 'text-primary-v font-semibold' : 'text-bg-inverse-alt-v'}`}
                    aria-current={lng === currentLang ? 'true' : undefined}
                >
                    <span class="lang-code text-sm font-mono">{lng.toUpperCase()}</span>
                    <span class="lang-name text-sm">{languageNames[lng]}</span>
                    {lng === currentLang && (
                        <svg class="w-4 h-4 ml-auto shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                    )}
                </a>
            </li>
        ))}
    </ul>
</div>

<script>
    // Only JS needed: toggle open/close of the dropdown
    document.querySelectorAll<HTMLElement>('.language-selector').forEach(sel => {
        const btn = sel.querySelector<HTMLButtonElement>('.language-button');
        const dropdown = sel.querySelector<HTMLElement>('.language-dropdown');
        if (!btn || !dropdown) return;

        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const open = !dropdown.hasAttribute('hidden');
            dropdown.toggleAttribute('hidden', open);
            btn.setAttribute('aria-expanded', String(!open));
        });

        document.addEventListener('click', (e) => {
            if (!sel.contains(e.target as Node)) {
                dropdown.setAttribute('hidden', '');
                btn.setAttribute('aria-expanded', 'false');
            }
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                dropdown.setAttribute('hidden', '');
                btn.setAttribute('aria-expanded', 'false');
            }
        });
    });
</script>
