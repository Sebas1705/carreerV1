---
interface Props {
    href: string;
    text: string;
    className?: string;
}

const { href, text, className = '' } = Astro.props;
---

<a href={href}
    data-backlink
    class={`inline-flex items-center gap-2 font-black text-white 
    text-xs xs:text-sm md:text-lg lg:text-xl
    bg-primary-v py-1 px-5 hover:bg-secondary-v rounded-full 
    transition-colors ${className}`}
>{text}</a>

<script>
    (function () {
        document.querySelectorAll('[data-backlink]').forEach(function (el) {
            el.addEventListener('click', function (e) {
                e.preventDefault();
                var target = el.getAttribute('href');
                if (window.history.length > 1) {
                    window.history.back();
                } else if (target) {
                    window.location.href = target;
                }
            });
        });
    })();
</script>
