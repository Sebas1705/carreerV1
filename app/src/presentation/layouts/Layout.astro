---
import type { Language } from '@/domain';

interface Props {
    lang?: Language;
    title?: string;
    description?: string;
}

const { 
    lang = 'es', 
    title = 'Sebastián - Full Stack Developer',
    description = 'Portfolio profesional de Sebastián - Desarrollador Full Stack especializado en arquitecturas limpias y soluciones escalables.'
} = Astro.props;

import "../styles/global.css";
---

<!DOCTYPE html>
<html lang={lang}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <meta name="generator" content={Astro.generator} />
        
        <!-- Fonts -->
        <!-- Preload local JetBrains Mono variable font (place in app/public/fonts/) -->
        <link rel="preload" href="/fonts/JetBrainsMono[wght].woff2" as="font" type="font/woff2" crossorigin>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
        
        <!-- Favicon -->
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        
        <title>{title}</title>
        
        <script is:inline>
            // Initialize theme before page loads to prevent flash
            const getThemePreference = () => {
                try {
                    const v = typeof localStorage !== 'undefined' ? localStorage.getItem('theme') : null;
                    if (v) return v;
                } catch (e) {}
                return window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            };

            const theme = getThemePreference();
            document.documentElement.setAttribute('data-theme', theme);
        </script>
    </head>
    <body>
        <slot />
    </body>
</html>
