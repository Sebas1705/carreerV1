---
import type { Language } from '@/domain';
import { translate } from '@/domain';
import Section from '@/presentation/features/common/Section.astro';

interface Props {
    lang: Language;
}

const { lang } = Astro.props as Props;

import { InMemorySoftSkillsLabelsRepository, InMemorySoftSkillRepository } from '@/data';
import { GetSoftSkillsLabelsUseCase, GetSoftSkillsUseCase } from '@/domain';

const softSkillsLabels = await new GetSoftSkillsLabelsUseCase(new InMemorySoftSkillsLabelsRepository()).execute();
const softSkills = await new GetSoftSkillsUseCase(new InMemorySoftSkillRepository()).execute();
---

<Section id="soft-skills" background='notebook' title={translate(softSkillsLabels.title, lang)} subtitle={translate(softSkillsLabels.subtitle, lang)}>
    <div class="grid gap-6 res-px-md mt-10
    grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-4">
        {softSkills.map((skill) => (
            <div class="fade-in bg-bg-surface-alt-v border-3 border-primary-v rounded-2xl p-4 text-center transition-transform duration-200 hover:-translate-y-1 hover:shadow-lg flex flex-col justify-around gap-4" title={translate(skill.name, lang)}>
                <div class="flex flex-col gap-5">
                    <div class="res-h1 pt-4
                    text-accent-v">~{skill.icon}~</div>
                    <h3 class="res-h2
                    font-bold text-secondary-v pt-4">{translate(skill.name, lang)}</h3>
                </div>
                
                <p class="res-h3 justified-tight
                text-bg-inverse-v p-2 pt-4">{translate(skill.description, lang)}</p>
            </div>
        ))}
    </div>
</Section>
