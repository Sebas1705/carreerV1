---
interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  ariaLabel?: string;
  rel?: string;
  target?: string;
}

const { href, type = 'button', class: className = '', ariaLabel, rel, target } = Astro.props as Props;
---

{href ? (
  <a href={href} class={`btn-primary ${className}`} aria-label={ariaLabel} rel={rel} target={target}>
    <slot />
  </a>
) : (
  <button type={type} class={`btn-primary ${className}`} aria-label={ariaLabel}>
    <slot />
  </button>
)}
